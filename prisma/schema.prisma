// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
  COMPANY
  DELIVERY_PARTNER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ListingType {
  SELL
  BUY
}

enum ListingStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum OrderStatus {
  CREATED
  ACCEPTED
  CONFIRMED
  REJECTED
  PAYMENT_PENDING
  PAYMENT_SUCCESS
  PROCESSING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  INITIATED
  PAID
  PENDING
  SUCCESS
  FAILED
  HELD
  RELEASED
  REFUNDED
}

enum DeliveryStatus {
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum OtpType {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

enum LeadRole {
  FARMER
  COMPANY
}

//////////////////////
// MODELS
//////////////////////

model User {
  user_id            String             @id @default(uuid())
  name               String
  phone_no           String             @unique
  password           String
  address            String
  email              String?            @unique
  gender             Gender?
  isBlocked          Boolean            @default(false)
  role               UserRole           @default(USER)
  verificationStatus VerificationStatus @default(PENDING)
  registrationStep   Int                @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveryPartner DeliveryPartner?

  farmDetails   FarmDetails?
  listings      MarketListing[]
  notifications Notification[]
  payments      Payment[]
  bankDetails   BankDetails?
  products      Product[]
  otps          Otp[]
  kyc           Kyc?

  @@index([phone_no])
}

model FarmDetails {
  id       String @id @default(uuid())
  userId   String @unique
  state    String
  district String
  village  String
  pincode  String
  landArea Float?

  user User @relation(fields: [userId], references: [user_id], onDelete: Cascade)
}

model Company {
  companyId      String @id @default(uuid())
  companyName    String
  registrationNo String @unique
  hqLocation     String
  gstNumber      String @unique

  email    String @unique
  password String

  gstCertificateUrl String?
  licenseDocUrl     String?
  profileImageUrl   String?

  verification VerificationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventories Inventory[]
  orders      Order[]
  payments    Payment[]
}

model Inventory {
  stockId     String @id @default(uuid())
  companyId   String
  stockName   String
  stockWeight Float
  stockPrice  Float

  company Company @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@index([companyId])
}

model Product {
  productId    String   @id @default(uuid())
  productName  String
  category     String
  unit         String
  productImage String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  listings MarketListing[]

  @@index([userId])
}

model MarketListing {
  listingId   String        @id @default(uuid())
  sellerId    String
  productId   String
  price       Float
  quantity    Float
  minOrder    Float?
  listingType ListingType
  status      ListingStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller  User    @relation(fields: [sellerId], references: [user_id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade)
  orders  Order[]

  @@index([sellerId])
  @@index([sellerId, status, listingType])
  @@index([productId])
  @@index([price])
  @@index([createdAt])
  @@index([status, listingType])
  @@index([status, listingType, createdAt])
}

model Order {
  orderId   String @id @default(uuid()) 
  listingId String
  companyId String
  sellerId  String
  productId String

  quantity   Float
  unitPrice  Float
  finalPrice Float

  productName     String
  productCategory String
  productUnit     String

  orderStatus   OrderStatus   @default(CREATED)
  paymentStatus PaymentStatus @default(INITIATED)

  farmerAccepted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing MarketListing @relation(fields: [listingId], references: [listingId])
  company Company       @relation(fields: [companyId], references: [companyId])

  payment  Payment?
  delivery Delivery?
  disputes Dispute[]

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([sellerId])
  @@index([sellerId, createdAt])
  @@index([listingId])
  @@index([orderStatus, createdAt])
}

model Delivery {
  deliveryId String @id @default(uuid())
  orderId    String @unique

  assignedBy String
  partnerId  String

  status DeliveryStatus @default(ASSIGNED)

  pickupTime   DateTime?
  deliveryTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order            @relation(fields: [orderId], references: [orderId])
  partner DeliveryPartner? @relation(fields: [partnerId], references: [id])

  @@index([orderId])
  @@index([partnerId])
  @@index([status])
  @@index([partnerId, status])
}

model DeliveryPartner {
  id     String @id @default(uuid())
  userId String @unique

  vehicleType   String
  licenseNumber String

  isAvailable Boolean @default(true)
  isActive    Boolean @default(true)

  currentLat Float?
  currentLng Float?
  lastSeenAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  deliveries Delivery[]

  @@index([isAvailable])
  @@index([isAvailable, isActive])
}

model Dispute {
  disputeId String @id @default(uuid())
  orderId   String
  raisedBy  String

  reason String
  status String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [orderId])

  @@index([orderId])
}

model Notification {
  nId       String   @id @default(uuid())
  userId    String
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  paymentId String @id @default(uuid())

  orderId   String @unique
  companyId String
  userId    String

  amount        Float
  amountInPaise Int
  currency      String        @default("INR")
  status        PaymentStatus @default(INITIATED)
  method        String?
  receipt       String?
  idempotencyKey String?
  failureReason String?
  releaseMode   String?
  releaseReference String?

  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  initiatedAt DateTime?
  paidAt      DateTime?
  heldAt      DateTime?
  releasedAt  DateTime?
  failedAt    DateTime?
  notes       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  transactions Transaction[]
  webhookEvents PaymentWebhookEvent[]

  @@index([orderId])
  @@index([userId])
  @@index([status, createdAt])
}

model PaymentWebhookEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  eventType String
  paymentId String?
  orderId   String?
  payload   Json
  createdAt DateTime @default(now())

  payment Payment? @relation(fields: [paymentId], references: [paymentId], onDelete: SetNull)

  @@index([paymentId])
  @@index([orderId])
  @@index([eventType, createdAt])
}

model BankDetails {
  id                     String @id @default(uuid())
  userId                 String @unique
  accountHolder          String
  bankName               String
  accountNumberEncrypted String
  accountNumberIV        String
  accountNumberLast4     String
  ifscEncrypted          String
  ifscIV                 String
  ifscLast4              String

  user         User          @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  transactionId String @id @default(uuid())
  bankDetailsId String
  paymentId     String

  bankDetails BankDetails @relation(fields: [bankDetailsId], references: [id], onDelete: Cascade)
  payment     Payment     @relation(fields: [paymentId], references: [paymentId], onDelete: Cascade)

  @@index([paymentId])
}

model Otp {
  otpId     String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  @@index([userId])
}

model Kyc {
  kycId      String   @id @default(uuid())
  userId     String   @unique
  docType    String
  docNo      String   @unique
  frontImage String
  backImage  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [user_id], onDelete: Cascade)
}

model Lead {
  id        String   @id @default(uuid())
  email     String   @unique
  role      LeadRole
  name      String?
  createdAt DateTime @default(now())

  @@map("leads")
}
