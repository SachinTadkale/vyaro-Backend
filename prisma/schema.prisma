// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  FARMER
  ADMIN
  COMPANY
  DELIVERY_PARTNER
  OWNER
}

enum DocumentType {
  AADHAAR
  PAN
  DRIVING_LICENSE
  VEHICLE_RC
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ListingType {
  SELL
  BUY
}

enum ListingStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum OrderStatus {
  CREATED
  ACCEPTED
  CONFIRMED
  REJECTED
  PAYMENT_PENDING
  PAYMENT_SUCCESS
  PROCESSING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  INITIATED
  PAID
  PENDING
  SUCCESS
  FAILED
  HELD
  ESCROWED
  RELEASED
  REFUNDED
  FROZEN
}

enum TransactionType {
  ORDER_PAYMENT // company pays (escrow)
  ESCROW_HOLD // money held
  ESCROW_RELEASE // release to farmer
  DELIVERY_PAYOUT // to delivery partner
  PLATFORM_COMMISSION // platform earnings
  REFUND // refund to company
  PENALTY // optional future
}

enum TransactionDirection {
  CREDIT
  DEBIT
}

enum ActorType {
  FARMER
  COMPANY
  DELIVERY_PARTNER
  PLATFORM
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PayoutStatus {
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum AuditEntityType {
  DISPUTE
  PAYMENT
}

enum DeliveryStatus {
  PENDING_ASSIGNMENT
  ASSIGNED
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum AssignmentType {
  SYSTEM
  ADMIN
}

enum OtpType {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

enum LeadRole {
  FARMER
  COMPANY
}

enum BroadcastType {
  SUCCESS
  ALERT
  MAINTENANCE
  IMPORTANT
  UPDATE
}

enum PriceDirection {
  UP
  DOWN
  STABLE
}

enum DemandLevel {
  LOW
  MEDIUM
  HIGH
}

enum TargetAudience {
  ALL
  USER
  COMPANY
  DELIVERY_PARTNER
}

enum VehicleType {
  TRACTOR   // assume trolley included
  MINI_TRUCK
  PICKUP
  TRUCK
  HEAVY_TRUCK
}

enum ProductUnit {
  KG
  GRAM
  DOZEN
  CRATE
  BOX
  QUINTAL
  TON
  LITER
  PIECE
  BUNDLE
}

enum ProductCategory {
  VEGETABLES
  FRUITS
  GRAINS
  MILK
  FLOWERS
}

//////////////////////
// MODELS
//////////////////////

model User {
  user_id            String             @id @default(uuid())
  name               String
  phone_no           String             @unique
  password           String
  address            String
  /// Localized address variants. Shape: { "hi": "...", "mr": "..." }
  /// Populated once on create/update via TranslationService.translateAddress()
  addressLocal       Json?
  email              String?            @unique
  gender             Gender?
  isBlocked          Boolean            @default(false)
  role               UserRole
  verificationStatus VerificationStatus @default(PENDING)
  registrationStep   Int                @default(1)
  profileImage       String?
  location           String?
  publicProfileId    String?            @unique
  qrShareToken       String?            @unique
  profileVisibility  Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveryPartner DeliveryPartner?

  farmDetails   FarmDetails?
  listings      MarketListing[]
  notifications Notification[]
  payments      Payment[]
  bankDetails   BankDetails?
  products      Product[]
  otps          Otp[]
  transactions      Transaction[]        @relation("UserTransactions")
  payouts           Payout[]
  kyc               Kyc[]
  settingAudits     SystemSettingAudit[] @relation("SettingAuditChangedBy")
  settingUpdates    SystemSetting[]      @relation("SettingUpdatedBy")
  routeToggleAudits RouteToggleAudit[]   @relation("RouteToggleAuditChangedBy")
  settingEvents     SystemSettingEvent[] @relation("SettingEventTriggeredBy")
  aiChatSessions    AiChatSession[]

  // AI Governance relations
  aiUsageLogs           AIUsageLog[]
  restrictionsReceived  UserAIRestriction[]  @relation("RestrictionTarget")
  restrictionsImposed   UserAIRestriction[]  @relation("RestrictionImposedBy")
  restrictionCodesCreated RestrictionCode[]

  @@index([phone_no])
}

model FarmDetails {
  id       String @id @default(uuid())
  userId   String @unique
  state    String
  district String
  village  String
  pincode  String
  landArea Float?
  /// Localized address fields. Shape: { "hi": { "state": "...", "district": "...", "village": "..." }, "mr": { ... } }
  /// Populated once on create/update via TranslationService.
  addressLocal Json?

  user User @relation(fields: [userId], references: [user_id], onDelete: Cascade)
}

model Company {
  companyId      String @id @default(uuid())
  companyName    String
  registrationNo String @unique
  hqLocation     String
  gstNumber      String @unique

  email    String @unique
  password String

  gstCertificateUrl String?
  licenseDocUrl     String?
  profileImageUrl   String?

  verification VerificationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventories  Inventory[]
  orders       Order[]
  payments     Payment[]
  transactions   Transaction[] @relation("CompanyTransactions")
  aiChatSessions AiChatSession[]
  aiUsageLogs    AIUsageLog[]
}

model Inventory {
  stockId     String @id @default(uuid())
  companyId   String
  stockName   String
  stockWeight Float
  stockPrice  Float

  company Company @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@index([companyId])
}

model Product {
  productId    String   @id @default(uuid())
  productName  String
  category     ProductCategory
  unit         ProductUnit
  productImage String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  listings MarketListing[]

  @@index([userId])
}

model MarketListing {
  listingId   String        @id @default(uuid())
  sellerId    String
  productId   String
  price       Float
  quantity    Float
  minOrder    Float?
  latitude    Float?
  longitude   Float?
  listingType ListingType
  status      ListingStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller  User    @relation(fields: [sellerId], references: [user_id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade)
  orders  Order[]

  @@index([sellerId])
  @@index([sellerId, status, listingType])
  @@index([productId])
  @@index([price])
  @@index([latitude, longitude])
  @@index([createdAt])
  @@index([status, listingType])
  @@index([status, listingType, createdAt])
  @@index([status, latitude, longitude])
}

model Order {
  orderId   String @id @default(uuid())
  listingId String
  companyId String
  sellerId  String
  productId String

  quantity   Float
  unitPrice  Float
  deliveryFee Float?
  platformFee Float?
  finalPrice Float

  productName     String
  productCategory ProductCategory
  productUnit     ProductUnit

  /// Snapshot of product/category translations at order time.
  /// Shape: { "name": { "en": "Tomato", "hi": "टमाटर", "mr": "टोमॅटो" }, "category": { ... } }
  /// Stored immutably — reflects translations as of order creation.
  productTranslations Json?

  orderStatus   OrderStatus   @default(CREATED)
  paymentStatus PaymentStatus @default(INITIATED)

  farmerAccepted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing MarketListing @relation(fields: [listingId], references: [listingId])
  company Company       @relation(fields: [companyId], references: [companyId])

  payment      Payment?
  delivery     Delivery?
  disputes     Dispute[]
  transactions Transaction[] @relation("OrderTransactions")

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([sellerId])
  @@index([sellerId, createdAt])
  @@index([listingId])
  @@index([orderStatus, createdAt])
}

model Delivery {
  deliveryId String @id @default(uuid())
  orderId    String @unique

  partnerId  String?
  assignedBy AssignmentType @default(SYSTEM) // SYSTEM for now

  status DeliveryStatus @default(PENDING_ASSIGNMENT)

  assignmentExpiresAt DateTime?
  assignmentStatus    String @default("OPEN") // OPEN, EXPIRED, MANUAL

  pickupOtp String?
  pickupOtpVerified Boolean @default(false)

  deliveryOtp String?
  deliveryOtpVerified Boolean @default(false)

  pickupTime   DateTime?
  deliveryTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order            @relation(fields: [orderId], references: [orderId])
  partner DeliveryPartner? @relation(fields: [partnerId], references: [id])

  @@index([orderId])
  @@index([partnerId])
  @@index([status])
  @@index([partnerId, status])
}

model DeliveryPartner {
  id     String @id @default(uuid())
  userId String @unique

  vehicleType   VehicleType
  vehicleNumber String
  licenseNumber String

  capacity Int?

  isAvailable Boolean @default(true)
  isActive    Boolean @default(true)

  currentLat Float?
  currentLng Float?
  lastSeenAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  deliveries Delivery[]

  @@index([isAvailable])
  @@index([isAvailable, isActive])
}

model Dispute {
  id                String        @id @default(uuid())
  orderId           String
  raisedBy          String
  raisedByActorType String
  reason            String
  description       String
  status            DisputeStatus @default(OPEN)
  resolutionNote    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  resolvedAt        DateTime?
  resolvedBy        String?

  order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model AuditLog {
  id          String          @id @default(uuid())
  entityType  AuditEntityType
  entityId    String
  action      String
  performedBy String
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([performedBy, createdAt])
}

model Notification {
  nId       String   @id @default(uuid())
  userId    String
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  paymentId String @id @default(uuid())

  orderId   String @unique
  companyId String
  userId    String

  amount           Float
  amountInPaise    Int
  platformFee      Float?
  deliveryFee      Float?
  farmerAmount     Float?
  currency         String        @default("INR")
  status           PaymentStatus @default(INITIATED)
  method           String?
  receipt          String?
  idempotencyKey   String?
  failureReason    String?
  releaseMode      String?
  releaseReference String?

  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  initiatedAt DateTime?
  paidAt      DateTime?
  heldAt      DateTime?
  releasedAt  DateTime?
  failedAt    DateTime?
  notes       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  transactions  Transaction[]
  webhookEvents PaymentWebhookEvent[]

  @@index([orderId])
  @@index([userId])
  @@index([status, createdAt])
}

model PaymentWebhookEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  eventType String
  paymentId String?
  orderId   String?
  payload   Json
  createdAt DateTime @default(now())

  payment Payment? @relation(fields: [paymentId], references: [paymentId], onDelete: SetNull)

  @@index([paymentId])
  @@index([orderId])
  @@index([eventType, createdAt])
}

model BankDetails {
  id                     String @id @default(uuid())
  userId                 String @unique
  accountHolder          String
  bankName               String
  accountNumberEncrypted String
  accountNumberIV        String
  accountNumberLast4     String
  ifscEncrypted          String
  ifscIV                 String
  ifscLast4              String

  user User @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  transactionId String @id @default(uuid())

  paymentId String
  orderId   String?

  userId    String?
  companyId String?

  actorType ActorType

  amount        Float
  amountInPaise Int
  currency      String @default("INR")

  type      TransactionType
  direction TransactionDirection
  status    TransactionStatus    @default(PENDING)

  isEscrow Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment Payment  @relation(fields: [paymentId], references: [paymentId], onDelete: Cascade)
  order   Order?   @relation("OrderTransactions", fields: [orderId], references: [orderId])
  user    User?    @relation("UserTransactions", fields: [userId], references: [user_id])
  company Company? @relation("CompanyTransactions", fields: [companyId], references: [companyId])

  @@index([userId, createdAt])
  @@index([companyId, createdAt])
}

model Payout {
  payoutId String @id @default(uuid())

  userId String
  amount Float

  status PayoutStatus @default(INITIATED)

  transactionId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [user_id])

  @@index([userId, status])
}

model Otp {
  otpId     String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  @@index([userId])
}

model Kyc {
  kycId      String   @id @default(uuid())
  userId     String

  docType    DocumentType
  docNo      String
  frontImage String
  backImage  String?

  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  @@unique([userId, docType])
}

model Lead {
  id        String   @id @default(uuid())
  email     String   @unique
  role      LeadRole
  name      String?
  createdAt DateTime @default(now())

  @@map("leads")
}

model Broadcast {
  id             String         @id @default(uuid())
  title          String
  message        String
  type           BroadcastType
  targetAudience TargetAudience
  isActive       Boolean        @default(true)
  publishAt      DateTime
  expiresAt      DateTime?
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  imageUrl String?
  ctaLabel String?
  ctaLink  String?

  @@index([isActive, publishAt])
  @@index([targetAudience, isActive, publishAt])
  @@index([type, createdAt])
  @@index([expiresAt])
}

model TranslationDictionary {
  id        String   @id @default(cuid())
  key       String   @unique   // normalized word
  original  String

  en        String
  hi        String
  mr        String

  usageCount Int      @default(1)   // optimization
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([key])
}

model MarketRate {
  id               String   @id @default(cuid())

  // Crop info
  commodity        String
  category         String?
  variety          String?
  grade            String?

  // Market location
  mandiName        String
  district         String
  state            String

  // Pricing
  minPrice         Float?
  maxPrice         Float?
  modalPrice       Float

  // Units
  unit             String @default("Quintal")

  // Trends
  previousPrice    Float?
  trendPercent     Float?
  priceDirection   PriceDirection?

  // Insights
  demandLevel      DemandLevel?

  // Metadata
  source           String?
  sourceRecordId   String?

  // Official record date
  recordedDate     DateTime

  // Sync tracking
  syncedAt         DateTime @default(now())

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([commodity])
  @@index([state])
  @@index([district])
  @@index([recordedDate])

  @@unique([commodity, mandiName, district, recordedDate])
}

//////////////////////
// SYSTEM CONTROLS
//////////////////////

enum SettingScope {
  GLOBAL
  COMPANY
  USER
}

enum SettingType {
  BOOLEAN
  STRING
  NUMBER
}

enum SettingCategory {
  FEATURE
  ROUTE
  CRON
  MAINTENANCE
  INTEGRATION
}

enum CreatedSource {
  SYSTEM_BOOTSTRAP
  ADMIN_PANEL
  MIGRATION
  API
}

model SystemSetting {
  id              String          @id @default(cuid())

  key             String          @unique
  displayName     String?

  value           String

  type            SettingType     @default(BOOLEAN)
  category        SettingCategory @default(FEATURE)

  scopeType       SettingScope    @default(GLOBAL)
  scopeId         String?

  groupKey        String?
  description     String?

  isCritical      Boolean         @default(false)
  isVisible       Boolean         @default(true)
  requiresRestart Boolean         @default(false)
  isSeededBySystem Boolean        @default(true)
  createdSource   CreatedSource?

  updatedById     String?
  updatedBy       User?           @relation("SettingUpdatedBy", fields: [updatedById], references: [user_id])
  lastChangedAt   DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  audits          SystemSettingAudit[]

  @@index([category])
  @@index([groupKey])
  @@index([key])
}

model SystemSettingAudit {
  id          String         @id @default(cuid())

  settingKey  String
  settingId   String?
  setting     SystemSetting? @relation(fields: [settingId], references: [id])

  oldValue    String
  newValue    String

  changedById String?
  changedBy   User?          @relation("SettingAuditChangedBy", fields: [changedById], references: [user_id])

  reason      String?

  createdAt   DateTime @default(now())

  @@index([settingKey])
  @@index([changedById])
  @@index([settingId])
}

model RouteToggle {
  id          String   @id @default(cuid())

  method      String
  path        String

  enabled     Boolean  @default(true)

  displayName String?
  description String?
  groupKey    String?
  moduleKey   String?

  isCritical  Boolean  @default(false)

  isSeededBySystem Boolean        @default(true)
  createdSource   CreatedSource?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String?

  audits      RouteToggleAudit[]

  @@unique([method, path])
  @@index([groupKey])
  @@index([moduleKey])
  @@index([enabled])
}

model RouteToggleAudit {
  id            String      @id @default(cuid())

  routeToggleId String
  routeToggle   RouteToggle @relation(fields: [routeToggleId], references: [id])

  oldValue      Boolean
  newValue      Boolean

  changedById   String
  changedBy     User        @relation("RouteToggleAuditChangedBy", fields: [changedById], references: [user_id])

  reason        String?

  createdAt     DateTime @default(now())

  @@index([routeToggleId])
  @@index([changedById])
}

enum ExternalSyncType {
  MARKET_RATES
}

enum ExternalSyncStatusType {
  SUCCESS
  FAILED
  RUNNING
  LOCKED
  STALE
}

model ExternalSyncStatus {
  id               String                 @id @default(cuid())
  syncType         ExternalSyncType       @unique
  status           ExternalSyncStatusType
  recordsProcessed Int?
  durationMs       Int?
  lastAttemptAt    DateTime?
  lastSuccessAt    DateTime?
  lastFailureAt    DateTime?
  errorMessage     String?
  source           String?
  isManualTrigger  Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
}

//////////////////////
// AI ASSISTANT MODELS
//////////////////////

enum AiRoleContext {
  FARMER
  COMPANY
  ADMIN
  OWNER
  DELIVERY_PARTNER
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AiChatStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model AiChatSession {
  id              String          @id @default(cuid())
  userId          String?
  companyId       String?
  wrapperId       String?
  roleContext     AiRoleContext

  title           String?
  lastMessage     String?
  language        String? // en hi mr
  totalMessages   Int             @default(0)

  status          AiChatStatus    @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?       // Soft delete support
  messages        AiChatMessage[]

  user            User?           @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  company         Company?        @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([updatedAt])
}

model AiChatMessage {
  id              String          @id @default(cuid())
  sessionId       String
  role            AiMessageRole

  message         String          @db.Text
  responseTimeMs  Int?
  tokenUsage      Int?
  modelUsed       String?
  providerUsed    String?         // Track actual model provider (e.g. GEMINI, OPENROUTER)
  metadata        Json?

  createdAt       DateTime        @default(now())
  session         AiChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model AiPromptTemplate {
  id              String          @id @default(cuid())
  title           String

  roleContext     AiRoleContext
  badgeLabel      String
  promptTemplate  String          @db.Text
  isActive        Boolean         @default(true)

  createdAt       DateTime        @default(now())
  @@index([roleContext])
}

//////////////////////
// NEW ENTERPRISE AI WRAPPER ENGINE
//////////////////////

enum AiProvider {
  OPENROUTER
  GEMINI
  OPENAI
  CLAUDE
  OLLAMA
  GROQ
}

enum AiWrapperStatus {
  ACTIVE
  DISABLED
  MAINTENANCE
}

model AiWrapper {
  id                String          @id @default(cuid())
  key               String
  version           Int             @default(1)
  status            AiWrapperStatus @default(ACTIVE)

  name              String
  description       String?

  provider          AiProvider
  modelName         String

  systemPrompt      String          @db.Text
  temperature       Float           @default(0.7)
  maxTokens         Int             @default(1200)

  // Declarative access controls
  allowedRoles      Json            // Array of UserRole strings (e.g. ["FARMER", "COMPANY"])
  
  // Declarative prompt interpolation config
  contextConfig     Json?           // Required context flags (e.g. ["WEATHER", "MARKET_RATES"])
  badgeConfig       Json?           // Suggested quick-action badges
  moderationConfig  Json?           // System instruction filter rules
  responseConfig    Json?           // Output JSON schema template if needed

  // Rate limiting policies
  rateLimitPerMin   Int             @default(20)

  // Capability toggles
  isStreaming       Boolean         @default(true)
  supportsTools     Boolean         @default(false)
  supportsVision    Boolean         @default(false)
  supportsJsonMode  Boolean         @default(false)
  isPublic          Boolean         @default(false)

  // Soft Delete & Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  @@unique([key, version]) // Enforces immutable configuration version chains
  @@index([key, status])
}

model AiWrapperUsage {
  id              String   @id @default(cuid())
  wrapperId       String
  userId          String?
  companyId       String?
  success         Boolean

  tokenUsage      Int?
  responseTimeMs  Int?
  errorMessage    String?

  // Cost tracking ledger
  estimatedCost   Float    @default(0.0)

  createdAt       DateTime @default(now())
  deletedAt       DateTime?

  @@index([wrapperId])
  @@index([createdAt])
}

model SystemSettingEvent {
  id                    String   @id @default(cuid())

  eventType             String

  settingKeys           Json

  triggeredById         String?
  triggeredBy           User?    @relation("SettingEventTriggeredBy", fields: [triggeredById], references: [user_id])

  settingsVersion       Int

  affectedClients       Int?

  broadcastDurationMs   Int?

  propagationStatus     String?

  metadata              Json?

  createdAt             DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
  @@index([settingsVersion])
}


//////////////////////
// AI GOVERNANCE & BILLING
//////////////////////

enum AIUsageStatus {
  SUCCESS
  FAILED
  BLOCKED
  RATE_LIMITED
  QUOTA_EXCEEDED
}

enum RestrictionSeverity {
  INFO
  WARNING
  BLOCK
  CRITICAL
}

/// Per-request AI usage log. Written after every AI completion attempt.
model AIUsageLog {
  id               String        @id @default(cuid())

  userId           String?
  user             User?         @relation(fields: [userId], references: [user_id])

  companyId        String?
  company          Company?      @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  role             UserRole

  provider         AiProvider
  modelName        String

  promptTokens     Int           @default(0)
  completionTokens Int           @default(0)
  totalTokens      Int           @default(0)

  estimatedCost    Float?

  requestPreview   String?       @db.VarChar(300)
  responsePreview  String?       @db.VarChar(300)

  route            String?
  module           String?

  status           AIUsageStatus
  latencyMs        Int?
  sessionId        String?

  contextHash        String?
  largestContributor String?

  createdAt        DateTime      @default(now())

  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
  @@index([provider])
  @@index([modelName])
  @@index([status])
  @@index([role])
}

/// Enterprise restriction code registry. Created by OWNER.
model RestrictionCode {
  id            String              @id @default(cuid())

  code          String              @unique

  title         String
  description   String

  severity      RestrictionSeverity

  httpStatus    Int                 @default(403)

  isActive      Boolean             @default(true)

  createdById   String
  createdBy     User                @relation(fields: [createdById], references: [user_id])

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  restrictions  UserAIRestriction[]

  @@index([code])
  @@index([severity])
  @@index([isActive])
}

/// Per-user active AI restrictions. Applied by OWNER or ADMIN.
model UserAIRestriction {
  id                String          @id @default(cuid())

  userId            String
  user              User            @relation("RestrictionTarget", fields: [userId], references: [user_id])

  restrictionCodeId String
  restrictionCode   RestrictionCode @relation(fields: [restrictionCodeId], references: [id])

  imposedById       String
  imposedBy         User            @relation("RestrictionImposedBy", fields: [imposedById], references: [user_id])

  reason            String?

  expiresAt         DateTime?

  isActive          Boolean         @default(true)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([userId, isActive])
}

/// AI token quota configuration per role or per individual user.
/// User-level quota overrides role-level quota.
model AIQuota {
  id                String    @id @default(cuid())

  role              UserRole?

  userId            String?   @unique

  monthlyTokenLimit Int       @default(20000)

  usedTokens        Int       @default(0)

  resetAt           DateTime

  isUnlimited       Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([role])
  @@index([userId])
}

